# Sync2k — Variables de Entorno
# Copia este archivo como .env y llena los valores de tu proyecto Supabase.
# NUNCA subas .env al repositorio (ya está en .gitignore).

# ─── Supabase (públicas — accesibles desde el cliente) ────────
PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...TU_ANON_KEY...

# ─── Supabase (privadas — SOLO servidor, nunca al cliente) ────
SUPABASE_SERVICE_ROLE_KEY=eyJ...TU_SERVICE_ROLE_KEY...
